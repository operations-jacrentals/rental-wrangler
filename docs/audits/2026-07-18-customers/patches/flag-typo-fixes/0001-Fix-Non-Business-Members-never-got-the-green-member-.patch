From bf1adcd88544d358bfbf125d8130ba9b96b3de68 Mon Sep 17 00:00:00 2001
From: operations-jacrentals <operations@jacrentals.com>
Date: Sat, 18 Jul 2026 21:34:38 -0500
Subject: [PATCH 1/2] Fix: Non-Business Members never got the green member name
 tint
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

ROWS.customers tinted a member's name green via:
  const isMember = c.accountType === 'Member' || c.accountType === 'Business Member';

'Member' is not a customerAccountType key. The keys are Non-Business,
Business, Non-Business Member, Business Member, Member Incomplete and
Blacklisted (config.js) — 'Member' is only the *label* rendered for the
Non-Business Member key. So the first disjunct was always false, and an
ordinary individual member never satisfied isMember. Only Business Members
got the green tint the line exists to give "Members in good standing", which
the comment directly above it already promised.

Corrected to compare the real key. A dead-code sweep separately flagged the
`=== 'Member'` disjunct as unreachable and safe to delete — deleting it would
have cemented the defect and removed the evidence of intent.

Visible change: customers with accountType 'Non-Business Member' whose flag
colour resolves green now render their name in green on the Customers list,
alongside Business Members. Nothing else moves.

Gates: smoke, logic-test, lease-test, lease-deploy-test, promote-test,
deck-test, cachebust-test, gen-rule-usage --check, check-window-catalog,
check-cachebust, check-design-md, gen-code-map --check — all green.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 app.js                     |  8 +++++-
 docs/code-map.generated.md | 58 +++++++++++++++++++-------------------
 2 files changed, 36 insertions(+), 30 deletions(-)

diff --git a/app.js b/app.js
index bd784f2..f062136 100644
--- a/app.js
+++ b/app.js
@@ -7142,7 +7142,13 @@ const ROWS = {
     // Name TINTED by the customer's flag color (Jac): red/yellow lead; green for Members
     // in good standing; a clear non-member keeps the calm default ink; archived/gray reads muted.
     const fc = getEntityColor('customers', c);
-    const isMember = c.accountType === 'Member' || c.accountType === 'Business Member';
+    // 'Non-Business Member', not 'Member': the customerAccountType KEYS are Non-Business /
+    // Business / Non-Business Member / Business Member / Member Incomplete / Blacklisted
+    // (config.js). 'Member' is only the *label* on the Non-Business Member key, so the old
+    // `=== 'Member'` compare could never be true and a Non-Business Member — the ordinary
+    // individual membership — never got the green name tint this line exists to give them.
+    // (audit 2026-07-18)
+    const isMember = c.accountType === 'Non-Business Member' || c.accountType === 'Business Member';
     const nameColor = (fc === 'red' || fc === 'yellow') ? `var(--${fc})` : fc === 'gray' ? 'var(--txt-3)' : (fc === 'green' && isMember) ? 'var(--green)' : 'var(--txt)';
     const sub = c.phone ? esc(c.phone) : '';
 
